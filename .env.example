# LLM configuration
# gemma2:2b  — recommended for local development (lightweight, ~1.5GB)
# gemma4:e2b — requires significant RAM, not recommended for 8GB RAM
# gpt-4o     — OpenAI, requires API key


# Local Ollama (default)
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma2:2b

# OpenAI example
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
